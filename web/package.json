{
  "name": "dau-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "generate:echo-course": "node src/data/build-echo-course.mjs",
