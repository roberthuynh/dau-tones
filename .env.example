# Optional. Dấu runs its complete offline practice loop without this key.
OPENAI_API_KEY=

# Production paid-call controls. Vercel Marketplace supplies KV_REST_API_*
# automatically when the free Upstash Redis resource is connected.
KV_REST_API_URL=
KV_REST_API_TOKEN=
DAU_CLIENT_ID_SECRET=
DAU_REVEAL_SIGNING_SECRET=
DAU_GUARD_MODE=local
DAU_GUARD_FAIL_CLOSED=true

# Optional per-route overrides use DAU_LIMIT_<ROUTE>_<FIELD>. Exact defaults
# are documented in README. Example: DAU_LIMIT_COACH_CLIENT_DAY=60.

# Build-time generation guardrails. The scripts target $10 and stop before $45.
DAU_BUILD_BUDGET_USD=10
DAU_BUILD_HARD_STOP_USD=45
